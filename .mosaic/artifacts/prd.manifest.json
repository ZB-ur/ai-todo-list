{
  "features": [
    "basic-arithmetic",
    "expression-display",
    "clear-and-backspace",
    "keyboard-support",
    "error-handling",
    "responsive-layout"
  ],
  "constraints": [
    "react-tailwind-stack",
    "frontend-only",
    "no-eval",
    "operator-precedence",
    "float-precision-display"
  ],
  "out_of_scope": [
    "scientific-calculation",
    "history",
    "parentheses",
    "unit-conversion",
    "theme-switching",
    "data-persistence",
    "i18n"
  ]
}